# Copy to `.env` in the repo root and fill in real values. Never commit `.env`.

ENV=development
DEMO_EMAIL=pm@pilotpm.demo
DEMO_PASSWORD=change-me
JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=480

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=pilotpm

LAVA_API_KEY=
LAVA_BASE=https://api.lava.so

GEMINI_API_KEY=
K2_API_KEY=
K2_API_BASE=https://api.k2think.ai

GITHUB_TOKEN=
GITHUB_REPO=owner/repo

SLACK_BOT_TOKEN=
SLACK_ENGINEERING_CHANNEL=#engineering
SLACK_STANDUP_CHANNEL=#standup-digest

MONDAY_API_KEY=

ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

HEX_API_KEY=

STAKEHOLDER_EMAILS=
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
